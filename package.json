{
  "name": "blog-svelte",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build && bun run build:pagefind",
    "build:pagefind": "pagefind -s .svelte-kit && bun run build:pagefind:dev && bun run build:pagefind:prod",
    "build:pagefind:dev": "rm -f -r static/pagefind && cp -R .svelte-kit/pagefind static/pagefind",
    "build:pagefind:prod": "rm -f -r dist/pagefind && cp -R .svelte-kit/pagefind dist/pagefind",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "new-post": "bun run scripts/new-post.ts"
  },
  "dependencies": {
    "mode-watcher": "^1.1.0",
    "overlayscrollbars": "^2.14.0",
    "pagefind": "^1.5.2",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@iconify/json": "^2.2.456",
    "@shikijs/rehype": "^4.0.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "bits-ui": "^2.16.3",
    "dayjs": "^1.11.20",
    "devalue": "^5.7.1",
    "gray-matter": "^4.0.3",
    "hastscript": "^9.0.1",
    "js-yaml": "^4.1.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "stringify-entities": "^4.0.4",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "unified": "^11.0.5",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1",
    "vite-plugin-md2svelte": "^0.0.1",
    "vite-plugin-pagefind": "^1.1.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2",
    "zod": "^4.3.6"
  }
}
